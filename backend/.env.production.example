# MailFlow backend — production env template.
# Copy to .env in your hosting provider (Railway, Fly, etc.) and fill in.

# --- runtime ---------------------------------------------------------------
ENV=production
DEBUG=false

# --- database & cache ------------------------------------------------------
# Railway provides these as references when you add Postgres + Redis plugins:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
#   REDIS_URL=${{Redis.REDIS_URL}}
# Note: SQLAlchemy needs the postgresql+psycopg:// prefix, not just postgres://
DATABASE_URL=postgresql+psycopg://USER:PASS@HOST:5432/DBNAME
REDIS_URL=redis://USER:PASS@HOST:6379/0

# --- secrets ---------------------------------------------------------------
# Generate fresh values FOR PRODUCTION — do not reuse dev values.
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=__GENERATE_64_HEX_CHARS__
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=__GENERATE_FERNET_KEY__

# --- auth ------------------------------------------------------------------
ACCESS_TOKEN_TTL_MIN=30
REFRESH_TOKEN_TTL_DAYS=14

# --- CORS ------------------------------------------------------------------
# Comma-separated origins. Must include your Vercel frontend URL exactly.
CORS_ORIGINS=["https://mailflow.vercel.app"]

# --- storage ---------------------------------------------------------------
# Set to "r2" to use Cloudflare R2 in production. Without these, the app
# falls back to local FS (only works if you have persistent disk attached).
STORAGE_BACKEND=r2
R2_ENDPOINT=https://YOUR_ACCOUNT.r2.cloudflarestorage.com
R2_ACCESS_KEY=__R2_ACCESS_KEY_ID__
R2_SECRET_KEY=__R2_SECRET_ACCESS_KEY__
R2_BUCKET=mailflow-attachments

# --- rate limiting (optional override) ------------------------------------
# Set to "1" to disable the per-IP rate limiter (don't do this in prod).
# RATE_LIMIT_DISABLED=0
