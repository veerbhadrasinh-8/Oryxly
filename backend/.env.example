# PRODUCTION NOTE: set ENV=production on the server. The app refuses to boot
# in production if any of these are left insecure:
#   - SECRET_KEY is the placeholder or < 32 chars
#   - FERNET_KEY is the placeholder or not a valid Fernet key
#   - DEBUG=true
#   - CORS_ORIGINS contains localhost / 127.0.0.1
# Generate keys:
#   SECRET_KEY:  openssl rand -hex 32
#   FERNET_KEY:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

ENV=development
DEBUG=true

DATABASE_URL=postgresql+psycopg://mailflow:mailflow@postgres:5432/mailflow
REDIS_URL=redis://redis:6379/0

SECRET_KEY=replace-with-openssl-rand-hex-32
FERNET_KEY=replace-with-fernet-generate-key

ACCESS_TOKEN_TTL_MIN=30
REFRESH_TOKEN_TTL_DAYS=14

CORS_ORIGINS=["http://localhost:3000"]
